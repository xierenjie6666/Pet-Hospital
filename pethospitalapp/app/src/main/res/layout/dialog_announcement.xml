<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_announcement">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_gradient_primary"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="20dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📢"
            android:textSize="36sp" />

        <TextView
            android:id="@+id/dialogAnnouncementTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="系统公告"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:gravity="center" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/dialogAnnouncementContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="公告内容"
            android:textSize="15sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingExtra="4dp"
            android:gravity="start" />

        <TextView
            android:id="@+id/dialogAnnouncementTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="12dp"
            android:layout_gravity="end" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/dontShowAgainCheckBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="今日不再提醒"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            app:buttonTint="@color/primary"
            android:minHeight="36dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dialogConfirmButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="我知道了"
            android:textSize="14sp"
            android:backgroundTint="@color/primary"
            app:cornerRadius="20dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp" />

    </LinearLayout>

</LinearLayout>
