<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_header_gradient"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_arrow_back"
                android:padding="6dp"
                app:tint="@color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="系统公告管理"
                android:textSize="20sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginStart="12dp" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="管理用户登录时显示的公告弹窗内容"
            android:textSize="13sp"
            android:textColor="#B3FFFFFF"
            android:layout_marginTop="6dp"
            android:layout_marginStart="48dp" />

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="-16dp">

        <ScrollView
            android:id="@+id/listSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardElevation="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:id="@+id/historyContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="加载中..."
                            android:textSize="14sp"
                            android:textColor="@color/text_hint"
                            android:gravity="center"
                            android:padding="24dp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/editSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="24dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardElevation="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📢"
                                android:textSize="22sp"
                                android:layout_marginEnd="10dp" />

                            <TextView
                                style="@style/SectionTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="编辑公告" />

                        </LinearLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/announcementTitleLayout"
                            style="@style/AppTextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:hint="公告标题"
                            app:startIconDrawable="@drawable/ic_appointment"
                            app:startIconTint="@color/primary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/announcementTitleInput"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:maxLines="1" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/announcementContentLayout"
                            style="@style/AppTextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:hint="公告内容"
                            app:startIconDrawable="@drawable/ic_symptoms"
                            app:startIconTint="@color/primary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/announcementContentInput"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:minLines="4"
                                android:gravity="top|start"
                                android:inputType="textMultiLine" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/announcementEnabledSwitch"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="设为展示公告"
                                android:textSize="15sp"
                                android:textColor="@color/text_primary"
                                app:thumbTint="@color/white"
                                app:trackTint="@color/primary_light"
                                app:thumbElevation="2dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/saveButton"
                                style="@style/AppButtonPrimary"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:text="保存公告"
                                android:textSize="14sp"
                                android:layout_marginEnd="8dp"
                                app:icon="@drawable/ic_check"
                                app:iconGravity="start"
                                app:iconSize="18dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/previewButton"
                                style="@style/AppButtonOutline"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:text="预览效果"
                                android:textSize="14sp"
                                android:layout_marginStart="8dp"
                                app:icon="@drawable/ic_view"
                                app:iconGravity="start"
                                app:iconSize="18dp" />

                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardElevation="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💡"
                                android:textSize="22sp"
                                android:layout_marginEnd="10dp" />

                            <TextView
                                style="@style/SectionTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="快捷模板" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipSpring"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="春季防疫"
                                app:chipBackgroundColor="@color/info_light"
                                android:textColor="@color/primary"
                                app:chipStrokeWidth="0dp"
                                android:layout_marginEnd="6dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipSummer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="夏季驱虫"
                                app:chipBackgroundColor="@color/success_light"
                                android:textColor="@color/success"
                                app:chipStrokeWidth="0dp"
                                android:layout_marginEnd="6dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipWinter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="冬季保暖"
                                app:chipBackgroundColor="@color/warning_light"
                                android:textColor="@color/warning"
                                app:chipStrokeWidth="0dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipHoliday"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="假期安排"
                                app:chipBackgroundColor="@color/stat_cancelled_bg"
                                android:textColor="@color/accent"
                                app:chipStrokeWidth="0dp"
                                android:layout_marginEnd="6dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipPromo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="优惠活动"
                                app:chipBackgroundColor="@color/stat_pending_bg"
                                android:textColor="@color/warning"
                                app:chipStrokeWidth="0dp" />

                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>

    </FrameLayout>

</LinearLayout>
