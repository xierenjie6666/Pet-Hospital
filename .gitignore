# ==========================================
# 宠物医院预约平台 Git忽略配置
# ==========================================

# ========== Java/Maven 构建产物 ==========
target/
*.class
*.jar
*.war
*.ear
*.log
*.ctxt
.mtj.tmp/
hs_err_pid*

# ========== Gradle 构建产物 ==========
.gradle/
build/
!gradle-wrapper.jar
!gradle-wrapper.properties
*.apk
*.aab

# ========== Node.js/前端 ==========
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json  # 可以选择性保留
dist/
.cache/

# ========== IDE配置文件 ==========
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.swp
*.swo
*~

# ========== 操作系统文件 ==========
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ========== 数据库文件 ==========
*.db
*.sqlite
*.sqlite3

# ========== 日志和临时文件 ==========
logs/
*.log
tmp/
temp/
*.tmp
*.bak
*.cache

# ========== 环境配置文件（包含敏感信息） ==========
.env
.env.local
.env.*.local
application-prod.yml
secrets.yml

# ========== 编译输出和缓存 ==========
out/
bin/
*.pyc
__pycache__/

# ========== 其他不需要的文件 ==========
*.md.backup
*.pdf
*.doc
*.docx
*.xls
*.xlsx

# ========== 保留某些重要文件 ==========
!README.md
!LICENSE
!CHANGELOG.md
!CONTRIBUTING.md